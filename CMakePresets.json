{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-x64-debug",
            "displayName": "Windows x64 Debug",
            "description": "Ninja generator, vcpkg toolchain, debug build",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/x64-Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "C:/Users/knyaz/vcpkg/scripts/buildsystems/vcpkg.cmake"
            },
            "environment": {
                "VCPERF_COLLECTOR_ENABLED": "0",
                "MSVC_BUILD_INSIGHTS_DISABLED": "1"
            }
        },
        {
            "name": "windows-x64-release",
            "displayName": "Windows x64 Release",
            "description": "Ninja generator, vcpkg toolchain, release build",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/x64-Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "C:/Users/knyaz/vcpkg/scripts/buildsystems/vcpkg.cmake"
            },
            "environment": {
                "VCPERF_COLLECTOR_ENABLED": "0",
                "MSVC_BUILD_INSIGHTS_DISABLED": "1"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-multimc-debug",
            "configurePreset": "windows-x64-debug",
            "targets": [
                "MultiMC"
            ]
        },
        {
            "name": "build-multimc-release",
            "configurePreset": "windows-x64-release",
            "targets": [
                "MultiMC"
            ]
        }
    ]
}